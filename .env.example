# ============================================================
# AI 模型配置（支持多模型智能路由）
# ============================================================
# 只需填写 API_KEY、BASE_URL、MODEL_NAME，程序会自动识别并选择正确的调用方式
# ============================================================

# API 密钥
API_KEY=your-api-key-here

# 模型名称，例如：
#   gemini-2.0-flash-exp、gemini-1.5-flash、gemini-1.5-pro
#   claude-sonnet-4-6           （Anthropic Claude）
#   gpt-4o                      （OpenAI GPT）
MODEL_NAME=gemini-2.0-flash-exp

# BASE_URL（程序根据域名自动判断调用方式，无需手动指定模式）
#
#   为空                           → Google Gemini 官方 REST API
#   包含 generativelanguage        → Gemini REST API（httpx 直调）
#   api.openai.com                → OpenAI SDK
#   其他自定义域名                  → httpx 直调 + 拼接 /chat/completions
#
# 示例：
#   https://generativelanguage.googleapis.com/v1beta    （Gemini 官方）
#   https://api.openai.com/v1                           （OpenAI 官方）
#   https://your-proxy.com/api/v1                        （Claude 兼容代理等）
#   https://your-ollama.com/v1                           （Ollama 等）
BASE_URL=

# 使用 Gemini 官方 SDK（默认 false，使用 REST API）
# 建议保持 false，REST API 更稳定
USE_GEMINI_SDK=false
